# =========================================================================
# InnerStyle Backend - environment variables (copy to .env and fill in)
# =========================================================================

# --- MeshyAI ---
# Get your key at https://www.meshy.ai/  (Settings -> API Keys)
MESHY_API_KEY=msy_your_api_key_here
MESHY_BASE_URL=https://api.meshy.ai
# Shared secret used to authenticate Meshy webhook callbacks (any random string).
# Send it from Meshy as the `X-Webhook-Secret` header (or configure in the dashboard).
MESHY_WEBHOOK_SECRET=change_me_random_secret

# --- Database (PostgreSQL) ---
DATABASE_URL=jdbc:postgresql://localhost:5432/innerstyle
DATABASE_USERNAME=innerstyle
DATABASE_PASSWORD=innerstyle

# --- Server ---
SERVER_PORT=2207
SPRING_PROFILES_ACTIVE=dev

# --- Redis (cache, JWT blacklist, rate limiting). App is fail-open if Redis is down. ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_KEY_PREFIX=is:dev
RATE_LIMIT_ENABLED=true

# --- Auth / JWT ---
# HMAC-SHA256 secret; MUST be >= 32 bytes and kept secret in production.
JWT_SECRET=change-me-please-use-a-long-random-secret-at-least-32-bytes
JWT_ACCESS_TTL=PT15M
JWT_REFRESH_TTL=P7D
# Frontend base URL used to build email verification / password reset links.
FRONTEND_BASE_URL=http://localhost:5173

# --- Social login (optional; leave blank to skip audience checks in dev) ---
GOOGLE_CLIENT_ID=
FACEBOOK_APP_ID=

# --- Payment: VNPay (sandbox: https://sandbox.vnpayment.vn) ---
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5173/wallet/vnpay-return

# --- Payment: MoMo (test: https://test-payment.momo.vn) ---
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_REDIRECT_URL=http://localhost:5173/wallet/momo-return
MOMO_IPN_URL=http://localhost:2207/api/common/payments/momo/ipn
