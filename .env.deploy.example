# =========================================================================
# InnerStyle deploy env (copy to .env next to docker-compose.yml, then edit)
# =========================================================================

# --- Database (used by both postgres and backend) ---
POSTGRES_DB=innerstyle
POSTGRES_USER=innerstyle
POSTGRES_PASSWORD=change_me_strong_password

# --- Auth / JWT (MUST change in production; >= 32 bytes) ---
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes
JWT_ACCESS_TTL=PT15M
JWT_REFRESH_TTL=P7D
# Public URL of the site — used to build email verification / reset links.
FRONTEND_BASE_URL=http://YOUR_EC2_PUBLIC_DNS

# --- Redis ---
REDIS_KEY_PREFIX=is:prod
RATE_LIMIT_ENABLED=true

# --- MeshyAI ---
MESHY_API_KEY=msy_your_api_key_here
MESHY_BASE_URL=https://api.meshy.ai
MESHY_WEBHOOK_SECRET=change_me_random_secret

# --- Social login (optional) ---
# Backend uses these to verify the token audience:
GOOGLE_CLIENT_ID=
FACEBOOK_APP_ID=
# Frontend embeds these at build time to show the Google/Facebook buttons
# (use the SAME values; leave blank to hide the buttons):
VITE_GOOGLE_CLIENT_ID=
VITE_FACEBOOK_APP_ID=

# --- Payment: VNPay ---
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://YOUR_EC2_PUBLIC_DNS/wallet/vnpay-return

# --- Payment: MoMo ---
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_REDIRECT_URL=http://YOUR_EC2_PUBLIC_DNS/wallet/momo-return
MOMO_IPN_URL=http://YOUR_EC2_PUBLIC_DNS/api/common/payments/momo/ipn
